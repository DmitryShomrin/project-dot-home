name: minio

services:
  minio:
    image: minio/minio:{{ docker_compose_minio_image_version }}
    container_name: minio
    restart: unless-stopped
    environment:
      MINIO_ROOT_USER: {{ docker_compose_minio_root_user }}
      MINIO_ROOT_PASSWORD: {{ docker_compose_minio_root_password }}
      MINIO_BROWSER_REDIRECT_URL: "https://{{ docker_compose_minio_console_domain }}"
      MINIO_SERVER_URL: "https://{{ docker_compose_minio_api_domain }}"
    user: "{{ getent_passwd[ansible_user].1 }}:{{ getent_passwd[ansible_user].2 }}"
    networks:
      - services
    volumes:
      - {{ docker_compose_minio_data_dir }}:/data
    command: server /data --console-address :9001
{% if docker_compose_minio_labels %}
    labels:
{% endif %}
{% for item in docker_compose_minio_labels %}
      - {{ item }}
{% endfor %}

networks:
  services:
    name: services
    external: true
